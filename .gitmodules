[submodule "site-lisp/extensions/emacs-deferred"]
	path = site-lisp/extensions/emacs-deferred
	url = https://github.com/kiwanami/emacs-deferred.git
[submodule "site-lisp/extensions/emacs-epc"]
	path = site-lisp/extensions/emacs-epc
	url = https://github.com/kiwanami/emacs-epc.git
[submodule "site-lisp/extensions/pyim"]
	path = site-lisp/extensions/pyim
	url = https://github.com/tumashu/pyim.git
[submodule "site-lisp/extensions/meow"]
	path = site-lisp/extensions/meow
	url = https://github.com/DogLooksGood/meow.git
