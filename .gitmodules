[submodule "site-lisp/extensions/auto-save"]
	path = site-lisp/extensions/auto-save
	url = git@github.com:manateelazycat/auto-save.git
[submodule "site-lisp/extensions/nyan-mode"]
	path = site-lisp/extensions/nyan-mode
	url = https://github.com/TeMPOraL/nyan-mode.git
[submodule "site-lisp/extensions/doom-modeline"]
	path = site-lisp/extensions/doom-modeline
	url = https://github.com/seagle0128/doom-modeline.git
[submodule "site-lisp/extensions/doom-themes"]
	path = site-lisp/extensions/doom-themes
	url = https://github.com/hlissner/emacs-doom-themes.git
[submodule "site-lisp/extensions/all-the-icons"]
	path = site-lisp/extensions/all-the-icons
	url = https://github.com/domtronn/all-the-icons.el.git
[submodule "site-lisp/extensions/emacs-winum"]
	path = site-lisp/extensions/emacs-winum
	url = https://github.com/deb0ch/emacs-winum.git
[submodule "site-lisp/extensions/emacs-which-key"]
	path = site-lisp/extensions/emacs-which-key
	url = https://github.com/justbur/emacs-which-key.git
[submodule "site-lisp/extensions/treemacs"]
	path = site-lisp/extensions/treemacs
	url = https://github.com/Alexander-Miller/treemacs.git
[submodule "site-lisp/extensions/projectile"]
	path = site-lisp/extensions/projectile
	url = https://github.com/bbatsov/projectile.git
[submodule "site-lisp/extensions/emacs-application-framework"]
	path = site-lisp/extensions/emacs-application-framework
	url = https://github.com/manateelazycat/emacs-application-framework.git
	ignore = dirty
[submodule "site-lisp/extensions/emacs-ctable"]
	path = site-lisp/extensions/emacs-ctable
